{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bun install",
  "buildCommand": "bun run build:web",
  "outputDirectory": "mobile/dist",
  "rewrites": [
    { "source": "/((?!_expo|assets|.*\\..*).*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/drilly.apk",
      "destination": "https://github.com/rjh-mopjones/drilly/releases/latest/download/drilly.apk",
      "permanent": false
    }
  ]
}
