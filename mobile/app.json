{
  "expo": {
    "name": "DRILLY",
    "slug": "drilly",
    "scheme": "drilly",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0d12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mjrjh.drilly"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "android": {
      "package": "com.mjrjh.drilly",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0d12"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "./plugins/withHardwareKeyIntercept.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "1ac3fd7a-3358-4682-835f-59362104a968"
      }
    }
  }
}
