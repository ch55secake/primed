erDiagram
    PROFILE ||--o{ SWIPE : initiates
    PROFILE ||--o{ SWIPE : targeted_by
    PROFILE ||--o{ MATCH : member_a
    PROFILE ||--o{ MATCH : member_b
    MATCH ||--o{ MESSAGE : carries
    PROFILE ||--o{ PHOTO : has

    PROFILE {
        bigint user_id PK
        int age
        enum gender
        json prefs
        float lat
        float lng
        timestamp last_active
    }
    SWIPE {
        bigint swiper_id FK
        bigint target_id FK
        enum direction
        timestamp ts
    }
    MATCH {
        bigint match_id PK
        bigint user_a FK
        bigint user_b FK
        timestamp created_at
        timestamp last_msg_ts
    }
    MESSAGE {
        bigint message_id PK
        bigint match_id FK
        bigint sender_id FK
        string text
        timestamp ts
    }
    PHOTO {
        bigint photo_id PK
        bigint user_id FK
        string url
        int order_idx
    }
