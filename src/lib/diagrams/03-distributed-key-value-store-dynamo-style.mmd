flowchart TB
    Client([Client])
    Coordinator[Coordinator Node<br/>any node]
    R1[(Replica 1<br/>LSM store)]
    R2[(Replica 2<br/>LSM store)]
    R3[(Replica 3<br/>LSM store)]
    Gossip[Gossip + Anti-entropy<br/>Merkle trees]

    Client -->|get / put| Coordinator
    Coordinator -->|forward W=2 / R=2| R1
    Coordinator -->|forward W=2 / R=2| R2
    Coordinator -->|forward W=2 / R=2| R3
    R1 <-.->|sync deltas| Gossip
    R2 <-.->|sync deltas| Gossip
    R3 <-.->|sync deltas| Gossip
    Coordinator -.->|hinted handoff / read repair| R3

    classDef external fill:#1e2533,stroke:#3a4a6e,color:#cfd6e6
    classDef service fill:#1a3a2e,stroke:#3a6e54,color:#cfe6d6
    classDef store fill:#1e2a3e,stroke:#3a5a8e,color:#cfdcef
    classDef config fill:#3a2e1a,stroke:#6e5a3a,color:#efdfcf

    class Client external
    class Coordinator service
    class R1,R2,R3 store
    class Gossip config
